# Environment Configuration

# API Configuration
REACT_APP_API_URL=http://localhost:3001
REACT_APP_ANALYTICS_URL=http://localhost:3001/analytics

# Watermark Configuration
REACT_APP_WATERMARK_TEXT=nurasyid
REACT_APP_WATERMARK_ENABLED=true

# Monetization
REACT_APP_ENABLE_MONETIZATION=true

# Features
REACT_APP_ENABLE_OCR=true
REACT_APP_ENABLE_CHAT=true
REACT_APP_ENABLE_IMAGE_UPLOAD=true
